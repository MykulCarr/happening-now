/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; font-src 'self' data: https:; connect-src 'self' https: https://cloudflareinsights.com; frame-src 'self' https:; media-src 'self' https: blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self' https://duckduckgo.com;

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: no-cache

/manifest.json
  Cache-Control: public, max-age=86400

# Static assets: cache for 1h, then revalidate via ETag. Service worker
# (network-first) still gets fresh content within 1h via its own logic;
# new deploys take effect immediately because HTML is uncached and the
# referenced asset URLs hit Cloudflare's CDN, which is purged on deploy.
/assets/*
  Cache-Control: public, max-age=3600, must-revalidate
