{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "happening-now",
  "compatibility_date": "2026-04-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".deploy-public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "happening-now.net/*",
      "zone_name": "happening-now.net"
    }
  ]
}